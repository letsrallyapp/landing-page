# Supabase credentials for the waitlist form.
# Copy this file to `.env.local` for local development.
# In production, set these as environment variables in the Vercel project.
#
# Find them in your Supabase project: Project Settings → API Keys
# Use the PUBLISHABLE key (sb_publishable_...) here — it is safe for the browser.
# Never put the SECRET key (sb_secret_...) in this file; it bypasses RLS.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
